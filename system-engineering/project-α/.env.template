# ============================================
# Diana - Phase 1 Configuration
# ============================================
# このファイルを .env にコピーしてAPIキーを設定してください
# cp .env.template .env

# --- LLM Provider ---
# 使用するプロバイダー (gemini | claude)
LLM_PROVIDER=gemini

# --- Gemini API ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# --- Claude API (Phase 1 optional) ---
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Embedding ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Paths ---
# データフォルダのルート (デフォルト: ./data)
DATA_DIR=./data

# --- Metacognition ---
# 知識充足判定の類似度閾値 (0.0 - 1.0)
KNOWLEDGE_THRESHOLD=0.35

# --- Conversation ---
# 保持する会話履歴のターン数
MAX_CONVERSATION_TURNS=20
